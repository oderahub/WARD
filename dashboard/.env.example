# =============================================================================
# Ward dashboard — Vite environment template
# -----------------------------------------------------------------------------
# Copy to `dashboard/.env.local` (which is gitignored by default in Vite) and
# fill in the slots below. ALL values here are PUBLIC because Vite inlines
# `VITE_*` vars into the client bundle at build time — never put secrets here.
#
# A fresh clone with NO `.env.local` boots fine: the dashboard falls back to
# the canonical NETWORKS[chainId] entries baked into src/lib/networks.ts, so
# you only need this file when overriding the defaults (forks, redeploys,
# registry address overrides, etc).
# =============================================================================

# --- WardAgentRegistry address override ------------------------------------
# Optional override for the WardAgentRegistry address. When unset, the
# dashboard reads `NETWORKS[chainId].registryAddress` (canonical Shannon
# deployment: 0x97F743A9AAa5AcAA73075C1B8F1921274755CF70). Only set this when
# running against a fork or a custom redeploy.
VITE_WARD_AGENT_REGISTRY=

# --- Target chain -------------------------------------------------------------
# Which network the dashboard targets. Unset/unrecognized => Somnia Shannon.
#   VITE_WARD_CHAIN=somnia   -> Somnia Shannon testnet (chainId 50312)
#   VITE_WARD_CHAIN=fuji     -> Avalanche Fuji C-Chain testnet (chainId 43113)
#
# Fuji requires BOTH VITE_WARD_ORACLE and VITE_WARD_QUEUE below. If either
# is missing or malformed, the dashboard logs a warning and falls back to
# Shannon rather than booting against an unusable network.
VITE_WARD_CHAIN=

# --- Avalanche Fuji deployment ------------------------------------------------
# Unlike Shannon, Fuji has no canonical deployment baked into networks.ts, so
# these must be supplied. Take them from contracts/deployments/43113.json after
#   forge script script/Deploy.s.sol --rpc-url avalanche_fuji --broadcast
VITE_WARD_ORACLE=
VITE_WARD_QUEUE=

# Optional Fuji RPC override (defaults to the public endpoint below).
VITE_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
