# =============================================================================
# Ward dashboard — Vite environment template
# -----------------------------------------------------------------------------
# Copy to `dashboard/.env.local` (which is gitignored by default in Vite) and
# fill in the slots below. ALL values here are PUBLIC because Vite inlines
# `VITE_*` vars into the client bundle at build time — never put secrets here.
#
# Ward has no canonical Avalanche deployment baked in yet, so VITE_WARD_ORACLE
# and VITE_WARD_QUEUE below are REQUIRED for the dashboard to do anything
# useful. Without them it still boots, but the active network points at the
# zero address.
# =============================================================================

# --- Target chain -------------------------------------------------------------
# Which Avalanche network the dashboard targets. Unset/unrecognized => Fuji,
# so a misconfigured env lands on testnet rather than mainnet.
#   VITE_WARD_CHAIN=fuji        -> Avalanche Fuji C-Chain testnet (chainId 43113)
#   VITE_WARD_CHAIN=avalanche   -> Avalanche C-Chain mainnet (chainId 43114)
VITE_WARD_CHAIN=fuji

# --- Deployed Ward contracts (REQUIRED) ---------------------------------------
# Take these from contracts/deployments/43113.json after running
#   forge script script/Deploy.s.sol --rpc-url avalanche_fuji --broadcast
VITE_WARD_ORACLE=
VITE_WARD_QUEUE=

# --- WardAgentRegistry address ------------------------------------------------
# Optional. When unset, the dashboard reads `NETWORKS[chainId].registryAddress`,
# which is also unset until a registry is deployed. Set this after running
# script/DeployRegistry.s.sol.
VITE_WARD_AGENT_REGISTRY=

# --- RPC overrides (optional; public endpoints are the defaults) ---------------
VITE_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
VITE_AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc
