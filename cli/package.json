{
  "name": "@sentry-somnia/cli",
  "version": "0.10.1",
  "private": true,
  "description": "Sentry CLI — compile + publish policies to SentryOracle; preflight + inspect intents",
  "type": "module",
  "bin": {
    "sentry": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx src/index.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry-somnia/sdk": "workspace:*",
    "cac": "^6.7.14",
    "kleur": "^4.1.5",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
