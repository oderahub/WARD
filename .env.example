# =============================================================================
# Ward — root environment template
# -----------------------------------------------------------------------------
# Copy this file to `.env` (which is gitignored) and fill in the slots below.
# `.env` is consumed by the `ward` CLI; forge scripts also pick up DEPLOYER_PK
# via the shell when you `set -a; source .env; set +a` before invoking `forge`.
#
# Wallet: bring your own funded Somnia testnet wallet. The keys below are NOT
# generated for you — paste an existing private key with STT in it.
# Faucets (manual; no programmatic API as of this release):
#   - https://testnet.somnia.network/   (official Shannon testnet faucet)
#   - https://faucet.somnia.network/    (alternate; gated)
# Recommended balance: >= 0.5 STT for a full live demo (deploy + createRequest).
# =============================================================================

# --- Wallet (REQUIRED for any write path) ------------------------------------
# Used by the CLI (`ward push`, `ward queue:*`, `ward preflight`, …) to
# sign transactions against WardOracle / WardQueue.
PRIVATE_KEY=

# Same key, named for forge scripts (`forge script ... --private-key $DEPLOYER_PK`).
# PRIVATE_KEY and DEPLOYER_PK MAY be the same value — the split exists only so
# CLI tooling and bare `forge` invocations can each read their conventional var
# name. If you set just one, copy it to the other before running deploy scripts.
DEPLOYER_PK=

# --- Chain ------------------------------------------------------------------
# Which network the CLI targets. Defaults to Somnia when unset.
#   WARD_CHAIN=somnia   -> Somnia Shannon testnet (chainId 50312)
#   WARD_CHAIN=fuji     -> Avalanche Fuji C-Chain testnet (chainId 43113)
WARD_CHAIN=somnia

# Default Somnia Shannon testnet RPC. Override only if you run a private node.
SOMNIA_TESTNET_RPC=https://dream-rpc.somnia.network

# Avalanche Fuji RPC (used when WARD_CHAIN=fuji). Native token is AVAX.
# Faucet: https://faucet.avax.network/  or  https://core.app/tools/testnet-faucet/
FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc

# --- Somnia agent platform (real testnet addresses; verified in-session) ----
SOMNIA_AGENT_PLATFORM=0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776
LLM_INFERENCE_AGENT_ID=12847293847561029384

# --- Deployed Ward contracts (Shannon testnet — chainId 50312) -------------
# These are the canonical live deployments. Leave as-is unless you re-deploy
# your own fork; redeploys write fresh addresses into
# `contracts/deployments/$CHAINID.json`.
# When WARD_CHAIN=fuji, replace these with your Fuji deployment addresses
# (from contracts/deployments/43113.json after the deploy).
WARD_ORACLE=0x3C7bF90f243d670a01f512221d9546e09fEaCC9c
WARD_QUEUE=0xFB715A37951Fc8dcc920120768e91f7C8bbA54c4

# --- Optional: Shannon explorer API key (only needed for contract verification)
SOMNIA_EXPLORER_KEY=
