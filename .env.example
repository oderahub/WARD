# =============================================================================
# Ward — root environment template
# -----------------------------------------------------------------------------
# Copy this file to `.env` (which is gitignored) and fill in the slots below.
# `.env` is consumed by the `ward` CLI; forge scripts also pick up DEPLOYER_PK
# via the shell when you `set -a; source .env; set +a` before invoking `forge`.
#
# Wallet: bring your own funded Avalanche Fuji wallet. The keys below are NOT
# generated for you — paste an existing private key with test AVAX in it.
# Faucets:
#   - https://faucet.avax.network/                  (official Fuji faucet)
#   - https://core.app/tools/testnet-faucet/        (Core; alternate)
# Recommended balance: >= 0.5 AVAX for a full live demo.
# =============================================================================

# --- Wallet (REQUIRED for any write path) ------------------------------------
# Used by the CLI (`ward push`, `ward queue:*`, `ward preflight`, …) to
# sign transactions against WardOracle / WardQueue.
PRIVATE_KEY=

# Same key, named for forge scripts (`forge script ... --private-key $DEPLOYER_PK`).
# PRIVATE_KEY and DEPLOYER_PK MAY be the same value — the split exists only so
# CLI tooling and bare `forge` invocations can each read their conventional var
# name. If you set just one, copy it to the other before running deploy scripts.
DEPLOYER_PK=

# --- Chain ------------------------------------------------------------------
# Which Avalanche network the CLI targets. Defaults to Fuji when unset.
#   WARD_CHAIN=fuji        -> Avalanche Fuji C-Chain testnet (chainId 43113)
#   WARD_CHAIN=avalanche   -> Avalanche C-Chain mainnet (chainId 43114)
WARD_CHAIN=fuji

# Avalanche Fuji RPC. Override only if you run a private node.
FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc

# Avalanche C-Chain mainnet RPC (used when WARD_CHAIN=avalanche).
AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc

# --- Deployed Ward contracts --------------------------------------------------
# Populate from `contracts/deployments/$CHAINID.json` after running
# `forge script script/Deploy.s.sol --rpc-url avalanche_fuji --broadcast`.
WARD_ORACLE=
WARD_QUEUE=

# --- Optional: Snowtrace/Routescan API key (contract verification only) -------
SNOWTRACE_API_KEY=
