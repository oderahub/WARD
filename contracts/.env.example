# Forge / contracts environment template.
# Copy to `contracts/.env` and fill in DEPLOYER_PK. All other values are the
# canonical Shannon testnet (chainId 50312) defaults.

# Private key used by `forge script ... --private-key $DEPLOYER_PK`.
# MAY be the same key as PRIVATE_KEY in the root `.env`.
DEPLOYER_PK=0x...

# Somnia Shannon testnet RPC (override only for a private node).
SOMNIA_TESTNET_RPC=https://dream-rpc.somnia.network

# Optional: Shannon explorer API key for `forge verify-contract`.
SOMNIA_EXPLORER_KEY=

# Somnia agent platform — real testnet address; verified in-session.
SOMNIA_AGENT_PLATFORM=0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776
LLM_INFERENCE_AGENT_ID=12847293847561029384

# Canonical live Sentry deployments on Shannon. Forge scripts read these via
# vm.envAddress; leave them set unless you are deploying a fresh fork.
SENTRY_ORACLE=0x3C7bF90f243d670a01f512221d9546e09fEaCC9c
SENTRY_QUEUE=0xFB715A37951Fc8dcc920120768e91f7C8bbA54c4
