DEMO.md

# Forge build + broadcast artifacts (contain deploy tx hashes, deployment metadata)
**/broadcast/
**/cache/
**/out/

# Private reproduction scripts (tied to our specific deployer wallet + addresses)
examples/**/*-and-record.sh
examples/**/*-and-trigger-*.sh
examples/**/exercise-*.sh
examples/**/deploy-and-*.sh

# Local scratch (playwriter screenshots, ad-hoc captures — never auto-clean, never push)
tmp/

# Superpowers brainstorming scratch (visual-companion mockups, session state)
.superpowers/

# Superpowers planning docs (AI-tooling scratch, not part of the shipped repo)
docs/superpowers/

# AI tooling scratch directories — per-user state, never share
.agents/
.codex/
.claude/
.cursor/
# EXCEPT the Ward skill pack generated by `ward ai:init --claude` (tracked
# so users can install the skill without running the CLI first). Narrowed to
# the ward-integration subdir only so other .claude/skills/ tooling output
# (playwriter worktrees, etc.) stays ignored.
!.claude/skills/ward-integration/
!.claude/skills/ward-integration/**

# Lean compiled build artifacts (re-derivable from .lean sources; tracked sources only)
verification/lean/.lake/

# Scratch artifacts written by PublishAndBind.s.sol and similar deploy helpers
contracts/deployments/.tmp-*

# Per-deploy outputs of examples/ward-counter/script/DeployAgent.s.sol +
# DeployCounter.s.sol (rewritten on every run; live addresses are hardcoded in
# examples/ward-react-app/src/App.tsx as the canonical source of truth).
examples/ward-counter/deployments/*.json
!examples/ward-counter/deployments/.gitkeep
.vercel

# NOTE: contracts/lib/forge-std is a git submodule (see .gitmodules) — tracked,
# not ignored, so CI's `submodules: recursive` checkout can fetch it.

# Changelog is Somnia-era history; excluded from the public Avalanche repo.
CHANGELOG.md

# Grant application narrative — internal strategy + unfilled brackets.
# Lives with the project but is NOT published to the public repo.
WARD_GRANT_NARRATIVE.md
