{
  "name": "sentry-react-app-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Demo dApp: gate a CounterAgent.bump write with useSentryGuardedWrite (chain source) against the live Somnia testnet SentryOracle.",
  "scripts": {
    "predev": "pnpm -F @sentry-somnia/sdk build && pnpm -F @sentry-somnia/react build",
    "prebuild": "pnpm -F @sentry-somnia/sdk build && pnpm -F @sentry-somnia/react build",
    "pretest": "pnpm -F @sentry-somnia/sdk build && pnpm -F @sentry-somnia/react build",
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry-somnia/react": "workspace:*",
    "@sentry-somnia/sdk": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
