{
  "name": "@ward/vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin that compiles POLICY.md files into evaluated policies at build time via `?eval-policy` imports.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@ward/sdk": "workspace:*",
    "vite": "^5.4.0"
  },
  "devDependencies": {
    "@ward/sdk": "workspace:*",
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
